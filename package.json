{
  "name": "csbot",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter @csbot/server dev",
    "build": "bun run --filter @csbot/server build",
    "check": "bun run --filter @csbot/server typecheck",
    "docker:up": "docker compose -f deploy/docker-compose.yml up -d",
    "docker:down": "docker compose -f deploy/docker-compose.yml down",
    "docker:logs": "docker compose -f deploy/docker-compose.yml logs -f"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
