# Server
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgres://csbot:csbot@localhost:5432/csbot

# Redis
REDIS_URL=redis://localhost:6379

# Vector Store: "qdrant" or "viking"
VECTOR_STORE_TYPE=qdrant

# Qdrant (if VECTOR_STORE_TYPE=qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=csbot_docs

# Viking DB (if VECTOR_STORE_TYPE=viking)
# VIKING_AK=your_access_key
# VIKING_SK=your_secret_key
# VIKING_REGION=cn-beijing
# VIKING_COLLECTION=csbot_docs
# VIKING_INDEX=csbot_docs_idx

# Embedding vector size
EMBEDDING_VECTOR_SIZE=1536

# LLM Provider
# Supported: anthropic, openai, google, deepseek, etc.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514

# API Keys (set the one matching your LLM_PROVIDER)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Custom Anthropic-compatible endpoint (optional)
# ANTHROPIC_BASE_URL=https://your-custom-endpoint.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your-auth-token

# Embedding (uses OpenAI's embedding API)
EMBEDDING_MODEL=text-embedding-3-small

# CORS (comma-separated origins, * for all)
CORS_ORIGINS=*
